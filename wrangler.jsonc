{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "real-cost-of-living",
  "compatibility_date": "2025-09-27",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "build"
  },
  "routes": [
    {
      "pattern": "realcostofliving.cc",
      "zone_name": "realcostofliving.cc"
    }
  ],
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
